# .env.example — Copy to .env and fill in all values before running the stack.
# All variables are REQUIRED. The stack will refuse to start if any are missing.

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_to_a_strong_password_32chars

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_to_a_strong_redis_password

# ── JWT signing key (min 32 characters, cryptographically random) ───────────
# Generate with: openssl rand -base64 32
JWT_KEY=change_me_to_at_least_32_bytes_secret_key!

# ── GitHub OAuth App credentials ────────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# ── Runner <-> API shared secret ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
RUNNER_TOKEN=change_me_to_a_strong_runner_service_token
