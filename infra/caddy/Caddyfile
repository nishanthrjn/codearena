
# Production Caddyfile — replace yourdomain.com
yourdomain.com {
    # Serve frontend
    handle /api/* {
        reverse_proxy api:5000
    }
    handle /hubs/* {
        reverse_proxy api:5000
    }
    handle {
        reverse_proxy web:80
    }

    tls your@email.com

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' wss://yourdomain.com"
    }

    log {
        output file /var/log/caddy/access.log
        format json
    }
}